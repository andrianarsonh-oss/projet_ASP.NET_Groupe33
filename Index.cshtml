@model List<EMIT_EDT.Models.Batiment>
@{
    ViewData["Title"] = "Bâtiments";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-building"></i> Bâtiments</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus"></i> Ajouter un bâtiment</a>
</div>

<div class="card">
    <div class="card-body">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Nom</th>
                    <th>Étages</th>
                    <th>Localisation</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model)
                {
                    <tr>
                        <td><strong>@b.Nom</strong></td>
                        <td>@b.NombreEtages</td>
                        <td>@b.Localisation</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@b.BatimentId" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                            <a asp-action="Delete" asp-route-id="@b.BatimentId" class="btn btn-sm btn-danger" onclick="return confirm('Supprimer ce bâtiment ?')"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.Any())
        {
            <p class="text-center text-muted">Aucun bâtiment enregistré.</p>
        }
    </div>
</div>