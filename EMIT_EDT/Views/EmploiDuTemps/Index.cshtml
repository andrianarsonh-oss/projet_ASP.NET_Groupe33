@model List<EMIT_EDT.Models.Seance>
@{
    ViewData["Title"] = "Emploi du Temps";
    var parcoursList = ViewBag.Parcours as List<EMIT_EDT.Models.Parcours> ?? new();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-calendar-alt text-primary"></i> Emploi du Temps</h2>
    <a asp-action="Create" class="btn btn-primary shadow-sm">
        <i class="fas fa-plus-circle me-1"></i> Créer une séance
    </a>
</div>

<!-- Filtres -->
<div class="card shadow-sm border-0 mb-4">
    <div class="card-body bg-light rounded">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label fw-semibold">
                    <i class="fas fa-graduation-cap me-1"></i> Parcours
                </label>
                <select name="parcoursId" class="form-select" onchange="this.form.submit()">
                    <option value="">-- Tous les parcours --</option>
                    @foreach (var p in parcoursList)
                    {
                        <option value="@p.ParcoursId" selected="@(Context.Request.Query["parcoursId"] == p.ParcoursId.ToString() ? true : false)">
                            @p.Code - @p.Nom (@p.Grade)
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-outline-primary w-100">
                    <i class="fas fa-filter me-1"></i> Filtrer
                </button>
            </div>
            <div class="col-md-6 text-end align-self-center">
                <span class="text-muted small">
                    <i class="fas fa-info-circle"></i> Cliquez sur un événement pour voir les détails.
                </span>
            </div>
        </form>
    </div>
</div>

<!-- Calendrier -->
<div class="card shadow-sm border-0">
    <div class="card-body p-3">
        <div id="calendar"></div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center mt-5">
        <i class="fas fa-calendar-times fa-4x text-muted mb-3"></i>
        <h5 class="text-muted">Aucune séance trouvée.</h5>
        <p class="text-muted">Commencez par <a asp-action="Create">créer une séance</a>.</p>
    </div>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var calendarEl = document.getElementById('calendar');
            if (!calendarEl) return;

            var events = [
                @foreach (var s in Model)
                {
                        <text>{
                            title: '@Html.Raw(s.MatiereUE?.Nom) (@s.Type)',
                            daysOfWeek: [@(s.JourSemaine - 1)],
                            startTime: '@s.CreneauHoraire?.HeureDebut.ToString(@"hh\:mm")',
                            endTime: '@s.CreneauHoraire?.HeureFin.ToString(@"hh\:mm")',
                            color: '@s.Couleur',
                            textColor: '#fff',
                            extendedProps: {
                                salle: '@s.Salle?.Code - @s.Salle?.Nom',
                                prof: '@s.Enseignant?.Utilisateur?.Nom @s.Enseignant?.Utilisateur?.Prenom',
                                promotion: '@s.Promotion?.Code',
                                matiere: '@s.MatiereUE?.Nom'
                            }
                        },</text>
                }
            ];

            var calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'timeGridWeek',
                height: 650,
                slotMinTime: '07:00:00',
                slotMaxTime: '19:00:00',
                allDaySlot: false,
                locale: 'fr',
                events: events,
                eventClick: function (info) {
                    const p = info.event.extendedProps;
                    Swal.fire({
                        title: p.matiere,
                        html: `<strong>Salle :</strong> ${p.salle}<br><strong>Professeur :</strong> ${p.prof}<br><strong>Promotion :</strong> ${p.promotion}`,
                        icon: 'info',
                        confirmButtonColor: '#1a3c5e'
                    });
                },
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'timeGridWeek,timeGridDay'
                },
                buttonText: {
                    today: 'Aujourd\'hui',
                    week: 'Semaine',
                    day: 'Jour'
                }
            });
            calendar.render();
        });
    </script>
    <!-- SweetAlert2 pour popups modernes -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
}