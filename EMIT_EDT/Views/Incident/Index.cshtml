@model List<EMIT_EDT.Models.Incident>
@{
    ViewData["Title"] = "Incidents";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-tools text-warning"></i> Incidents</h2>
    <a asp-action="Create" class="btn btn-danger"><i class="fas fa-plus"></i> Signaler un incident</a>
</div>

<div class="card">
    <div class="card-body">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Date</th>
                    <th>Salle</th>
                    <th>Type</th>
                    <th>Niveau</th>
                    <th>Statut</th>
                    <th>Description</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var i in Model)
                {
                    <tr>
                        <td>@i.DateSignalement.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@i.Salle?.Code - @i.Salle?.Batiment?.Nom</td>
                        <td>@i.TypePanne</td>
                        <td>
                            @if (i.NiveauUrgence == 3)
                            {
                                <span class="badge bg-danger">Urgent</span>
                            }
                            else if (i.NiveauUrgence == 2)
                            {

                                <span class="badge bg-warning text-dark">Moyen</span>
                            }
                            else
                            {

                                <span class="badge bg-info">Faible</span>
                            }
                        </td>
                        <td>@i.Statut</td>
                        <td>@i.Description</td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.Any())
        {
            <p class="text-center text-muted">Aucun incident signalé.</p>
        }
    </div>
</div>