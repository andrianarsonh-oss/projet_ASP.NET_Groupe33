@model List<EMIT_EDT.Models.Etudiant>
@{
    ViewData["Title"] = "Étudiants";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-user-graduate"></i> Étudiants</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus"></i> Ajouter un étudiant</a>
</div>

<div class="card">
    <div class="card-body">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Matricule</th>
                    <th>Nom</th>
                    <th>Prénom</th>
                    <th>Email</th>
                    <th>Parcours</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Model)
                {
                    <tr>
                        <td>@e.Matricule</td>
                        <td>@e.Nom</td>
                        <td>@e.Prenom</td>
                        <td>@e.Email</td>
                        <td>
                            @if (e.Avoirs != null && e.Avoirs.Any())
                            {
                                var premier = e.Avoirs.FirstOrDefault();
                                <span>@premier?.Parcours?.Code</span>
                            }
                            else
                            {
                                <span class="text-muted">Aucun</span>
                            }
                        </td>
                        <td>
                            @if (e.StatutValide)
                            {
                                <span class="badge bg-success">Actif</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactif</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@e.Id" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                            <a asp-action="Delete" asp-route-id="@e.Id" class="btn btn-sm btn-danger" onclick="return confirm('Supprimer cet étudiant ?')"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.Any())
        {
            <p class="text-center text-muted">Aucun étudiant enregistré.</p>
        }
    </div>
</div>