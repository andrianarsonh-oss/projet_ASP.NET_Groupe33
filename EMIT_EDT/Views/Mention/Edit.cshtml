@model EMIT_EDT.Models.Mention
@{
    ViewData["Title"] = "Modifier une mention";
}

<h2><i class="fas fa-edit"></i> Modifier la mention</h2>
<hr />

<form asp-action="Edit" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>
    <input type="hidden" asp-for="MentionId" />

    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="Code" class="form-label">Code</label>
            <input asp-for="Code" class="form-control" required />
            <span asp-validation-for="Code" class="text-danger"></span>
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="Nom" class="form-label">Nom</label>
            <input asp-for="Nom" class="form-control" required />
            <span asp-validation-for="Nom" class="text-danger"></span>
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="Description" class="form-label">Description</label>
            <input asp-for="Description" class="form-control" />
        </div>
    </div>

    <button type="submit" class="btn btn-success">
        <i class="fas fa-save"></i> Enregistrer
    </button>
    <a asp-action="Index" class="btn btn-secondary">Annuler</a>
</form>