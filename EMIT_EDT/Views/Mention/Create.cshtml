@model EMIT_EDT.Models.Mention
@{
    ViewData["Title"] = "Ajouter une mention";
}

<h2><i class="fas fa-plus-circle"></i> Ajouter une mention</h2>
<hr />

<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="Code" class="form-label">Code</label>
            <input asp-for="Code" class="form-control" required placeholder="Ex: MGMT" />
            <span asp-validation-for="Code" class="text-danger"></span>
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="Nom" class="form-label">Nom</label>
            <input asp-for="Nom" class="form-control" required placeholder="Ex: Management" />
            <span asp-validation-for="Nom" class="text-danger"></span>
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="Description" class="form-label">Description</label>
            <input asp-for="Description" class="form-control" placeholder="Description (optionnelle)" />
        </div>
    </div>

    <button type="submit" class="btn btn-success">
        <i class="fas fa-save"></i> Enregistrer
    </button>
    <a asp-action="Index" class="btn btn-secondary">Annuler</a>
</form>