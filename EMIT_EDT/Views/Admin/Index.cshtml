@model List<EMIT_EDT.Models.Admin>
@{
    ViewData["Title"] = "Administrateurs";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-user-shield"></i> Administrateurs</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus"></i> Ajouter un administrateur</a>
</div>

<div class="card">
    <div class="card-body">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Nom</th>
                    <th>Email</th>
                    <th>Fonction</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var admin in Model)
                {
                    <tr>
                        <td>@admin.Nom</td>
                        <td>@admin.Email</td>
                        <td>@admin.Fonction</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@admin.Id" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                            <a asp-action="Delete" asp-route-id="@admin.Id" class="btn btn-sm btn-danger" onclick="return confirm('Supprimer cet administrateur ?')"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.Any())
        {
            <p class="text-center text-muted">Aucun administrateur enregistré.</p>
        }
    </div>
</div>