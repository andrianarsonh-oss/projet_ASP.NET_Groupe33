@{
    ViewData["Title"] = "Statistiques";
}

<h2 class="mb-4">
    <i class="fas fa-chart-bar"></i> Tableau de bord statistique
</h2>

@* Indicateurs clés *@
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm bg-primary bg-opacity-10">
            <div class="card-body text-center">
                <i class="fas fa-calendar-check fa-2x text-primary mb-2"></i>
                <h4 class="fw-bold text-primary">@ViewBag.TotalSeances</h4>
                <p class="text-muted mb-0">Séances actives</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm bg-success bg-opacity-10">
            <div class="card-body text-center">
                <i class="fas fa-door-open fa-2x text-success mb-2"></i>
                <h4 class="fw-bold text-success">@ViewBag.SallesOccupees / @ViewBag.TotalSalles</h4>
                <p class="text-muted mb-0">Salles occupées (sur total)</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm bg-warning bg-opacity-10">
            <div class="card-body text-center">
                <i class="fas fa-tools fa-2x text-warning mb-2"></i>
                <h4 class="fw-bold text-warning">@ViewBag.SallesMaintenance</h4>
                <p class="text-muted mb-0">Salles en maintenance</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm bg-danger bg-opacity-10">
            <div class="card-body text-center">
                <i class="fas fa-exclamation-triangle fa-2x text-danger mb-2"></i>
                <h4 class="fw-bold text-danger">@ViewBag.IncidentsOuverts</h4>
                <p class="text-muted mb-0">Incidents ouverts</p>
            </div>
        </div>
    </div>
</div>

@* Section graphique (placeholder pour futures intégrations) *@
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white fw-semibold">
        <i class="fas fa-chart-line me-2"></i> Tendance d’occupation des salles
    </div>
    <div class="card-body text-center py-5">
        <i class="fas fa-chart-area fa-3x text-muted mb-3"></i>
        <p class="text-muted">Des graphiques interactifs pourront être affichés ici (Chart.js, etc.)</p>
    </div>
    <div class="card-footer bg-white text-end small text-muted">
        Données actualisées en temps réel
    </div>
</div>

<p class="mt-4 text-muted small">
    <i class="fas fa-info-circle"></i> Cette vue affiche les indicateurs clés de l'activité de l'établissement.
    Pour obtenir des données précises, assurez‑vous que des salles, bâtiments, séances et incidents ont été enregistrés.
</p>