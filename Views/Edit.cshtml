@model EMIT_EDT.Models.Enseignant
@{
    ViewData["Title"] = "Modifier un professeur";
}

<h2>Modifier le professeur</h2>
<hr />

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="EnseignantId" />
    <div asp-validation-summary="All" class="text-danger"></div>

    <!-- Informations de l'utilisateur (pré-remplies) -->
    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">Nom</label>
            <input name="nom" class="form-control" value="@Model.Utilisateur?.Nom" />
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label">Prénom</label>
            <input name="prenom" class="form-control" value="@Model.Utilisateur?.Prenom" />
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label">Email</label>
            <input name="email" type="email" class="form-control" value="@Model.Utilisateur?.Email" />
        </div>
        <!-- On ne remet pas le mot de passe ici, il faudrait un formulaire dédié -->
    </div>

    <!-- Champs Enseignant -->
    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="Matricule" class="form-label">Matricule</label>
            <input asp-for="Matricule" class="form-control" required />
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="Titre" class="form-label">Titre</label>
            <input asp-for="Titre" class="form-control" />
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="Contact" class="form-label">Contact</label>
            <input asp-for="Contact" class="form-control" />
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="DureTravaille" class="form-label">Durée de travail</label>
            <input asp-for="DureTravaille" type="number" class="form-control" />
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="Statut" class="form-label">Statut</label>
            <select asp-for="Statut" class="form-select">
                <option value="Permanent">Permanent</option>
                <option value="Vacataire">Vacataire</option>
            </select>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Enregistrer</button>
    <a asp-action="Index" class="btn btn-secondary">Annuler</a>
</form>