@model List<EMIT_EDT.Models.Enseignant>
@{
    ViewData["Title"] = "Professeurs";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-chalkboard-teacher"></i> Professeurs</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus"></i> Ajouter un professeur</a>
</div>

<div class="card">
    <div class="card-body">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Matricule</th>
                    <th>Nom complet</th>
                    <th>Titre</th>
                    <th>Contact</th>
                    <th>Email</th>
                    <th>Matières</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var prof in Model)
                {
                    <tr>
                        <td>@prof.Matricule</td>
                        <td>@prof.Utilisateur?.Nom @prof.Utilisateur?.Prenom</td>
                        <td>@prof.Titre</td>
                        <td>@prof.Contact</td>
                        <td>@prof.Utilisateur?.Email</td>
                        <td>
                            @if (prof.Matieres != null && prof.Matieres.Any())
                            {
                                var matieres = string.Join(", ", prof.Matieres.Select(m => m.Code));
                                <span>@matieres</span>
                            }
                            else
                            {
                                <span class="text-muted">Aucune</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@prof.EnseignantId" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                            <a asp-action="Delete" asp-route-id="@prof.EnseignantId" class="btn btn-sm btn-danger" onclick="return confirm('Supprimer ce professeur ?')"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.Any())
        {
            <p class="text-center text-muted">Aucun professeur enregistré.</p>
        }
    </div>
</div>