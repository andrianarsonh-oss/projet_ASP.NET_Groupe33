@model GestionSalleEmploiTemps.Models.AffectationProfesseurCours

@{
    ViewData["Title"] = "Nouvelle Affectation";
}

<style>
    .form-page {
        max-width: 720px;
        margin: 40px auto;
        padding: 0 20px;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    }

    /* Header breadcrumb */
    .form-breadcrumb {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        color: #888;
        margin-bottom: 18px;
    }

        .form-breadcrumb a {
            color: #534AB7;
            text-decoration: none;
        }

            .form-breadcrumb a:hover {
                text-decoration: underline;
            }

        .form-breadcrumb span {
            color: #ccc;
        }

    /* Main card */
    .form-container {
        background: #fff;
        border: 0.5px solid #e0e0e0;
        border-top: 4px solid #7F77DD;
        border-radius: 0 0 14px 14px;
        padding: 32px;
    }

    /* Header */
    .form-header {
        margin-bottom: 28px;
    }

        .form-header h2 {
            font-size: 20px;
            font-weight: 500;
            color: #26215C;
            margin: 0 0 4px;
        }

        .form-header p {
            font-size: 13px;
            color: #888;
            margin: 0;
        }

    /* Section titles */
    .section-title {
        font-size: 11px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #7F77DD;
        border-bottom: 0.5px solid #CECBF6;
        padding-bottom: 6px;
        margin: 24px 0 16px;
    }

    /* Form groups */
    .form-group-custom {
        display: flex;
        flex-direction: column;
        margin-bottom: 18px;
    }

    .form-label-custom {
        font-size: 12px;
        font-weight: 500;
        color: #444;
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: 0.03em;
    }

    .form-control-custom {
        width: 100%;
        padding: 0 12px;
        border: 0.5px solid #d0d0d0;
        border-radius: 8px;
        font-size: 13px;
        color: #222;
        background: #fafafa;
        height: 38px;
        box-sizing: border-box;
        transition: border-color 0.15s, box-shadow 0.15s;
    }

        .form-control-custom:focus {
            border-color: #7F77DD;
            outline: none;
            box-shadow: 0 0 0 3px rgba(127,119,221,0.15);
            background: #fff;
        }

    /* Select accent colors */
    select.sel-niveau {
        border-left: 3px solid #7F77DD;
    }

    select.sel-classe {
        border-left: 3px solid #D4537E;
    }

    select.sel-statut {
        border-left: 3px solid #1D9E75;
    }

    select.sel-prof {
        border-left: 3px solid #D85A30;
    }

    .grid-2 {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
    }

    /* Validation */
    .validation-summary-custom {
        background: #FCEBEB;
        border: 0.5px solid #F09595;
        border-left: 3px solid #E24B4A;
        border-radius: 8px;
        padding: 12px 16px;
        margin-bottom: 20px;
        color: #791F1F;
        font-size: 13px;
    }

    .field-validation-error {
        font-size: 12px;
        color: #E24B4A;
        margin-top: 4px;
        font-weight: 500;
    }

    /* Stats pills (top of form) */
    .form-pills {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 20px;
    }

    .form-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
    }

    .pill-prof {
        background: #FAECE7;
        color: #712B13;
    }

    .pill-niveau {
        background: #EEEDFE;
        color: #3C3489;
    }

    .pill-classe {
        background: #FBEAF0;
        color: #72243E;
    }

    .pill-date {
        background: #E1F5EE;
        color: #085041;
    }

    /* Actions */
    .actions-panel {
        border-top: 0.5px solid #eee;
        padding-top: 20px;
        margin-top: 28px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .btn-custom {
        padding: 9px 20px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        cursor: pointer;
        height: 38px;
        box-sizing: border-box;
        text-decoration: none;
        border: none;
        transition: background 0.15s;
    }

    .btn-back {
        background: #f4f4f4;
        color: #444;
        border: 0.5px solid #ddd;
    }

        .btn-back:hover {
            background: #e8e8e8;
            color: #222;
            text-decoration: none;
        }

    .btn-save {
        background: #534AB7;
        color: #EEEDFE;
        font-weight: 500;
    }

        .btn-save:hover {
            background: #3C3489;
            color: #fff;
        }

    @@media(max-width: 600px) {
        .grid-2 {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="form-page">

    <div class="form-breadcrumb">
        <a asp-action="Index"><i class="bi bi-list-ul"></i> Affectations</a>
        <span>›</span>
        <span>Nouvelle affectation</span>
    </div>

    <div class="form-container">

        <div class="form-header">
            <h2>Nouvelle affectation enseignant – cours</h2>
            <p>Associer un professeur à une matière, un niveau et une classe spécifique.</p>
        </div>

        <form asp-action="Create" method="post">

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState[string.Empty]?.Errors.Count > 0)
            {
                <div class="validation-summary-custom">
                    <strong>Erreur de validation :</strong>
                    <div asp-validation-summary="ModelOnly"></div>
                </div>
            }

            <!-- Section 1 : Enseignant -->
            <div class="section-title">Enseignant responsable</div>

            <div class="form-group-custom">
                <label asp-for="ProfesseurId" class="form-label-custom">Enseignant</label>
                <select asp-for="ProfesseurId" class="form-control-custom sel-prof"
                        asp-items="ViewBag.ProfesseurId">
                    <option value="">-- Choisir un enseignant --</option>
                </select>
                <span asp-validation-for="ProfesseurId" class="field-validation-error"></span>
            </div>

            <!-- Section 2 : Cours -->
            <div class="section-title">Informations du cours</div>

            <div class="grid-2">
                <div class="form-group-custom">
                    <label asp-for="NomCours" class="form-label-custom">Intitulé du cours</label>
                    <input asp-for="NomCours" class="form-control-custom"
                           placeholder="Ex: Algorithmique avancée" />
                    <span asp-validation-for="NomCours" class="field-validation-error"></span>
                </div>
                <div class="form-group-custom">
                    <label asp-for="CodeCours" class="form-label-custom">Code du cours</label>
                    <input asp-for="CodeCours" class="form-control-custom"
                           placeholder="Ex: INF-201" />
                    <span asp-validation-for="CodeCours" class="field-validation-error"></span>
                </div>
            </div>

            <!-- Section 3 : Niveau & Classe -->
            <div class="section-title">Niveau &amp; Classe</div>

            <div class="grid-2">
                <div class="form-group-custom">
                    <label asp-for="Niveau" class="form-label-custom">Niveau d'études</label>
                    <select asp-for="Niveau" class="form-control-custom sel-niveau">
                        <option value="">-- Choisir un niveau --</option>
                        @foreach (var n in (List<string>)(ViewData["NiveauxDisponibles"] ?? new List<string>()))
                        {
                            <option value="@n">@n</option>
                        }
                    </select>
                    <span asp-validation-for="Niveau" class="field-validation-error"></span>
                </div>
                <div class="form-group-custom">
                    <label asp-for="Classe" class="form-label-custom">Classe / Mention</label>
                    <select asp-for="Classe" class="form-control-custom sel-classe">
                        <option value="">-- Choisir une classe --</option>
                        @foreach (var c in (List<string>)(ViewData["ClassesDisponibles"] ?? new List<string>()))
                        {
                            <option value="@c">@c</option>
                        }
                    </select>
                    <span asp-validation-for="Classe" class="field-validation-error"></span>
                </div>
            </div>

            <!-- Section 4 : Dates & Statut -->
            <div class="section-title">Planification</div>

            <div class="grid-2">
                <div class="form-group-custom">
                    <label asp-for="DateAffectation" class="form-label-custom">Date de début</label>
                    <input asp-for="DateAffectation" type="date" class="form-control-custom" />
                    <span asp-validation-for="DateAffectation" class="field-validation-error"></span>
                </div>
                <div class="form-group-custom">
                    <label asp-for="Statut" class="form-label-custom">Statut</label>
                    <select asp-for="Statut" class="form-control-custom sel-statut">
                        <option value="">-- Choisir un statut --</option>
                        @foreach (var s in (ViewData["Statuts"] as List<string> ?? new()))
                        {
                            <option value="@s">@s</option>
                        }
                    </select>
                    <span asp-validation-for="Statut" class="field-validation-error"></span>
                </div>
            </div>

            <div class="actions-panel">
                <a asp-action="Index" class="btn-custom btn-back">
                    <i class="bi bi-arrow-left"></i> Annuler
                </a>
                <button type="submit" class="btn-custom btn-save">
                    <i class="bi bi-check-lg"></i> Enregistrer l'affectation
                </button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
