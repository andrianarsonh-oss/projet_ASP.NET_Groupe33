@model GestionSalleEmploiTemps.Models.AffectationProfesseurCours

@{
    ViewData["Title"] = "Modifier l'affectation";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Modification de l'affectation</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit">
                <input type="hidden" asp-for="Id" />

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="ProfesseurId" class="form-label">Enseignant</label>
                        <select asp-for="ProfesseurId" class="form-select" asp-items="ViewBag.ProfesseurId"></select>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="NomCours" class="form-label"></label>
                        <input asp-for="NomCours" class="form-control" />
                        <span asp-validation-for="NomCours" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="CodeCours" class="form-label"></label>
                        <input asp-for="CodeCours" class="form-control" />
                        <span asp-validation-for="CodeCours" class="text-danger"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Niveau" class="form-label">Niveau</label>
                        <select asp-for="Niveau" class="form-select">
                            @foreach (var item in (List<string>)ViewData["NiveauxDisponibles"]!)
                            {
                                <!option value="@item" @(Model.Niveau == item ? "selected" : "")>@item</!option>
                            }
                        </select>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Classe" class="form-label">Parcours</label>
                        <select asp-for="Classe" class="form-select">
                            @foreach (var item in (List<string>)ViewData["ClassesDisponibles"]!)
                            {
                                <!option value="@item" @(Model.Classe == item ? "selected" : "")>@item</!option>
                            }
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="DateAffectation" class="form-label"></label>
                        <input asp-for="DateAffectation" class="form-control" type="date" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Statut" class="form-label"></label>
                        <select asp-for="Statut" class="form-select">
                            @foreach (var st in (List<string>)ViewData["Statuts"]!)
                            {
                                <!option value="@st" @(Model.Statut == st ? "selected" : "")>@st</!option>
                            }
                        </select>
                    </div>
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-success">Enregistrer les modifications</button>
                    <a asp-action="Index" class="btn btn-secondary">Annuler</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}