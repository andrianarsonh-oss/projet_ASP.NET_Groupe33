@model GestionSalleEmploiTemps.Models.AffectationProfesseurCours

@{
    ViewData["Title"] = "Supprimer l'affectation";
}

<style>
    .delete-page {
        max-width: 600px;
        margin: 40px auto;
        padding: 20px;
    }

    .delete-card {
        background: #fff;
        border: 1px solid #fee2e2;
        border-radius: 12px;
        padding: 32px;
        box-shadow: 0 4px 6px -1px rgba(220, 38, 38, 0.1);
    }

    .warning-text {
        color: #b91c1c;
        font-weight: 600;
        margin-bottom: 20px;
    }

    .details-list {
        margin-bottom: 24px;
    }

    .details-row {
        display: flex;
        padding: 12px 0;
        border-bottom: 1px solid #f3f4f6;
    }

    .dt-label {
        width: 40%;
        color: #6b7280;
        font-size: 14px;
    }

    .dd-value {
        width: 60%;
        font-weight: 600;
        color: #111827;
    }

    .actions {
        display: flex;
        gap: 12px;
        margin-top: 24px;
    }

    .btn-delete {
        background-color: #dc2626;
        color: white;
        padding: 10px 20px;
        border-radius: 8px;
        border: none;
        font-weight: 600;
    }

        .btn-delete:hover {
            background-color: #b91c1c;
        }

    .btn-cancel {
        background-color: #f3f4f6;
        color: #374151;
        padding: 10px 20px;
        border-radius: 8px;
        text-decoration: none;
    }
</style>

<div class="delete-page">
    <div class="delete-card">
        <h2>Supprimer l'affectation</h2>
        <p class="warning-text">⚠️ Attention : Cette action est irréversible.</p>

        <div class="details-list">
            <div class="details-row"><div class="dt-label">Cours</div><div class="dd-value">@Model.NomCours (@Model.CodeCours)</div></div>
            <div class="details-row"><div class="dt-label">Enseignant</div><div class="dd-value">@(Model.Professeur?.Nom.ToUpper() + " " + Model.Professeur?.Prenom)</div></div>
            <div class="details-row"><div class="dt-label">Niveau</div><div class="dd-value">@Model.Niveau</div></div>
            <div class="details-row"><div class="dt-label">Classe</div><div class="dd-value">@Model.Classe</div></div>
            <div class="details-row"><div class="dt-label">Statut</div><div class="dd-value">@Model.Statut</div></div>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="actions">
                <button type="submit" class="btn-delete">Confirmer la suppression</button>
                <a asp-action="Index" class="btn-cancel">Annuler</a>
            </div>
        </form>
    </div>
</div>