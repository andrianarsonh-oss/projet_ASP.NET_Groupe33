@model GestionSalleEmploiTemps.Models.Professeur

@{
    ViewData["Title"] = "Révocation et Suppression du profil";
}

<style>
    /* Base UI Pro - Style Alerte Entreprise */
    .delete-page-container {
        max-width: 680px;
        margin: 60px auto;
        padding: 0 20px;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        color: #1e293b;
    }

    /* La Carte de Confirmation principale */
    .danger-card {
        background: #ffffff;
        border: 1px solid #fca5a5; /* Bordure rouge alerte subtile */
        border-radius: 12px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.05);
        overflow: hidden;
    }

    /* Bandeau d'avertissement supérieur */
    .danger-banner {
        background-color: #fef2f2; /* Rouge très clair */
        border-bottom: 1px solid #fee2e2;
        padding: 24px;
        display: flex;
        gap: 16px;
        align-items: flex-start;
    }

    .danger-icon-wrapper {
        background-color: #fee2e2;
        color: #dc2626;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .danger-banner-text h1 {
        font-size: 18px;
        font-weight: 600;
        color: #991b1b; /* Rouge foncé texte */
        margin: 0 0 4px 0;
    }

    .danger-banner-text p {
        font-size: 14px;
        color: #b91c1c;
        margin: 0;
        line-height: 1.5;
    }

    /* Corps de la carte : Récapitulatif de la fiche */
    .danger-body {
        padding: 32px;
        background: #ffffff;
    }

    .identity-summary-box {
        display: flex;
        align-items: center;
        gap: 20px;
        background: #f8fafc; /* Fond gris pro neutre */
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 24px;
    }

    .delete-avatar {
        width: 64px;
        height: 64px;
        border-radius: 8px;
        object-fit: cover;
        border: 1px solid #cbd5e1;
    }

    .identity-details h2 {
        font-size: 16px;
        font-weight: 600;
        color: #0f172a;
        margin: 0 0 4px 0;
    }

    .identity-details p {
        font-size: 13px;
        color: #475569;
        margin: 0;
    }

    /* Liste des impacts administratifs */
    .impact-notice {
        font-size: 13px;
        color: #64748b;
        line-height: 1.6;
        margin-bottom: 8px;
    }

    .impact-list {
        margin: 0 0 24px 0;
        padding-left: 20px;
        font-size: 13px;
        color: #475569;
    }

        .impact-list li {
            margin-bottom: 6px;
        }

    /* Barre d'actions inversée (Annuler mis en avant pour la sécurité) */
    .danger-actions {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        border-top: 1px solid #e2e8f0;
        padding-top: 24px;
    }

    /* Boutons de niveau système */
    .btn-action {
        height: 40px;
        padding: 0 20px;
        border-radius: 6px;
        font-size: 14px;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        box-sizing: border-box;
        cursor: pointer;
        transition: all 0.1s ease;
        border: 1px solid transparent;
    }

    .btn-cancel {
        background-color: #ffffff;
        color: #344054;
        border: 1px solid #d0d5dd;
        box-shadow: 0 1px 2px rgba(16, 24, 40, 0.05);
    }

        .btn-cancel:hover {
            background-color: #f9fafb;
            color: #1e293b;
        }

    .btn-confirm-delete {
        background-color: #d92d20; /* Rouge destructif international */
        color: #ffffff;
        font-weight: 600;
        box-shadow: 0 1px 2px rgba(16, 24, 40, 0.05);
    }

        .btn-confirm-delete:hover {
            background-color: #b42318;
        }

    /* Responsive */
    @@media (max-width: 580px) {
        .danger-banner {
            flex-direction: column;
            gap: 12px;
        }

        .identity-summary-box {
            flex-direction: column;
            text-align: center;
        }

        .danger-actions {
            flex-direction: column-reverse;
        }

        .btn-action {
            width: 100%;
            justify-content: center;
        }
    }
</style>

<div class="delete-page-container">
    <div class="danger-card">

        <div class="danger-banner">
            <div class="danger-icon-wrapper">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                    <line x1="12" y1="9" x2="12" y2="13"></line>
                    <line x1="12" y1="17" x2="12.01" y2="17"></line>
                </svg>
            </div>
            <div class="danger-banner-text">
                <h1>Action destructive irréversible</h1>
                <p>Vous êtes sur le point de supprimer définitivement ce compte de la base de données de l'établissement.</p>
            </div>
        </div>

        <div class="danger-body">
            <p class="impact-notice">Veuillez confirmer que vous ciblez le bon dossier d'enseignant :</p>

            <div class="identity-summary-box">
                @if (!string.IsNullOrEmpty(Model.PhotoUrl))
                {
                    <img src="@Model.PhotoUrl" class="delete-avatar" alt="Photo" />
                }
                else
                {
                    <img src="https://ui-avatars.com/api/?name=@Model.Nom+@Model.Prenom&background=2563eb&color=fff&size=100" class="delete-avatar" alt="Avatar" />
                }
                <div class="identity-details">
                    <h2>@Model.Nom @Model.Prenom</h2>
                    <p>Matricule : <strong>@Model.MatriculeProfesseur</strong> — @Model.Specialite</p>
                    <p>Affectation : Département @Model.Departement</p>
                </div>
            </div>

            <p class="impact-notice"><strong>Conséquences de la validation :</strong></p>
            <ul class="impact-list">
                <li>L'accès de cet utilisateur à la plateforme sera immédiatement révoqué.</li>
                <li>Ses affectations actuelles dans la gestion des salles de cours seront suspendues.</li>
                <li>Cette action est enregistrée dans le journal d'audit de sécurité du système.</li>
            </ul>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="danger-actions">
                    <a asp-action="Index" class="btn-action btn-cancel">
                        Annuler, conserver la fiche
                    </a>

                    <button type="submit" class="btn-action btn-confirm-delete">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                        Confirmer la suppression
                    </button>
                </div>
            </form>
        </div>

    </div>
</div>