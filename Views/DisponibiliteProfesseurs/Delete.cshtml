@model GestionSalleEmploiTemps.Models.DisponibiliteProfesseur

@{
    ViewData["Title"] = "Supprimer la disponibilité";
}

<style>
    /* Structure Globale Entreprise */
    .delete-page {
        max-width: 600px;
        margin: 60px auto;
        padding: 0 20px;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    }

    .delete-card {
        background: #ffffff;
        border: 1px solid #fee2e2;
        border-radius: 12px;
        padding: 32px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        text-align: center;
    }

    .warning-icon {
        background-color: #fef2f2;
        color: #dc2626;
        width: 56px;
        height: 56px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px auto;
        border: 1px solid #fca5a5;
    }

    .delete-card h2 {
        font-size: 20px;
        color: #111827;
        margin: 0 0 8px 0;
        font-weight: 600;
    }

    .delete-card p {
        color: #6b7280;
        font-size: 14px;
        margin: 0 0 24px 0;
    }

    /* Résumé des informations en lecture seule */
    .info-summary {
        background-color: #f9fafb;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 16px;
        text-align: left;
        margin-bottom: 28px;
        font-size: 14px;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 1px solid #f3f4f6;
    }

        .info-row:last-child {
            border-bottom: none;
        }

    .info-label {
        color: #4b5563;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 11px;
        letter-spacing: 0.03em;
    }

    .info-value {
        color: #111827;
        font-weight: 500;
    }

    /* Badges de Statut */
    .status-badge {
        display: inline-block;
        padding: 2px 8px;
        font-size: 12px;
        font-weight: 600;
        border-radius: 50px;
        border: 1px solid transparent;
    }

    .status-disponible {
        background-color: #ecfdf5;
        color: #065f46;
        border-color: #a7f3d0;
    }

    .status-occupe {
        background-color: #fffbeb;
        color: #92400e;
        border-color: #fde68a;
    }

    .status-danger {
        background-color: #fef2f2;
        color: #991b1b;
        border-color: #fca5a5;
    }

    /* Barre d'actions */
    .actions-panel {
        display: flex;
        justify-content: space-between;
        gap: 16px;
    }

    .btn-custom {
        flex: 1;
        padding: 10px 20px;
        border-radius: 6px;
        font-weight: 500;
        font-size: 14px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        border: 1px solid transparent;
        cursor: pointer;
        transition: background-color 0.15s ease;
    }

    .btn-cancel {
        background-color: #ffffff;
        color: #374151;
        border-color: #d1d5db;
    }

        .btn-cancel:hover {
            background-color: #f9fafb;
        }

    .btn-delete {
        background-color: #dc2626;
        color: #ffffff;
        font-weight: 600;
    }

        .btn-delete:hover {
            background-color: #b91c1c;
        }
</style>

<div class="delete-page">
    <div class="delete-card">

        <div class="warning-icon">
            <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
        </div>

        <h2>Supprimer cette disponibilité ?</h2>
        <p>Cette action est définitive. Confirmez-vous le retrait de ce créneau de l'emploi du temps ?</p>

        <div class="info-summary">
            <div class="info-row">
                <span class="info-label">Enseignant</span>
                <span class="info-value">
                    @(Model.Professeur != null ? $"{Model.Professeur.Nom.ToUpper()} {Model.Professeur.Prenom}" : "Non défini")
                </span>
            </div>

            <div class="info-row">
                <span class="info-label">Jour sélectionné</span>
                <span class="info-value">@Model.Jour</span>
            </div>

            <div class="info-row">
                <span class="info-label">Plage Horaire</span>
                <span class="info-value">
                    @Model.HeureDebut.ToString(@"hh\:mm") à @Model.HeureFin.ToString(@"hh\:mm")
                </span>
            </div>

            <div class="info-row">
                <span class="info-label">Statut appliqué</span>
                <span class="info-value">
                    @if (Model.Statut == "Disponible")
                    {
                        <span class="status-badge status-disponible">Disponible</span>
                    }
                    else if (Model.Statut == "Occupé")
                    {
                        <span class="status-badge status-occupe">Occupé</span>
                    }
                    else
                    {
                        <span class="status-badge status-danger">@Model.Statut</span>
                    }
                </span>
            </div>
        </div>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />

            <div class="actions-panel">
                <a asp-action="Index" class="btn-custom btn-cancel">
                    Annuler, conserver
                </a>

                <button type="submit" class="btn-custom btn-delete">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path><line x1="10" y1="11" x2="10" y2="17"></line><line x1="14" y1="11" x2="14" y2="17"></line></svg>
                    Confirmer la suppression
                </button>
            </div>
        </form>

    </div>
</div>