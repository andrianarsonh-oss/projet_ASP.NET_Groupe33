@model EMIT_EDT.Models.Batiment
@{
    ViewData["Title"] = "Ajouter un bâtiment";
}

<h2><i class="fas fa-plus-circle"></i> Ajouter un bâtiment</h2>
<hr />

<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="Nom" class="form-label">Nom</label>
            <input asp-for="Nom" class="form-control" required placeholder="Ex: Bâtiment A" />
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="NombreEtages" class="form-label">Nombre d'étages</label>
            <input asp-for="NombreEtages" type="number" class="form-control" min="1" max="10" value="1" required />
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="Localisation" class="form-label">Localisation</label>
            <input asp-for="Localisation" class="form-control" placeholder="Ex: Campus principal" />
        </div>
    </div>

    <button type="submit" class="btn btn-success"><i class="fas fa-save"></i> Enregistrer</button>
    <a asp-action="Index" class="btn btn-secondary">Annuler</a>
</form>